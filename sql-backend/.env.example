# Choose your database
DB_KIND=postgres            # or: mysql
PORT=4000
# Simple bearer token the browser app sends (leave blank for open dev)
API_TOKEN=

# Option A: a single connection string
DATABASE_URL=postgres://user:pass@localhost:5432/placementos
# DATABASE_URL=mysql://user:pass@localhost:3306/placementos

# Option B: discrete vars (used if DATABASE_URL is empty)
DB_HOST=localhost
DB_USER=placement
DB_PASS=secret
DB_NAME=placementos
DB_PORT=5432
