# ---- Google OAuth (both must be the SAME OAuth 2.0 Web Client ID) ----
# Frontend (Vite exposes only VITE_-prefixed vars to the browser):
VITE_GOOGLE_CLIENT_ID=1234567890-abcdefg.apps.googleusercontent.com
# Backend (used to verify the ID token's audience):
GOOGLE_CLIENT_ID=1234567890-abcdefg.apps.googleusercontent.com

# ---- Session ----
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string

# ---- Optional: restrict to your Google Workspace domain ----
# Leave blank to allow any verified Google account.
ALLOWED_HOSTED_DOMAIN=cutm.ac.in

# ---- Existing PlacementOS vars ----
GEMINI_API_KEY=your-gemini-key
APP_URL=http://localhost:5173
NODE_ENV=development
