// firestore.rules
// Server-enforced RBAC for the PlacementOS real-time database.
// A user's role is stored in /users/{uid}.role and mirrored to a custom auth claim.
// Deploy with: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function role() { return request.auth.token.role; }
    function staff() {
      return role() in ['Placement Officer', 'Administrator', 'Career Coordinator', 'Pursuit Manager'];
    }

    // Read-mostly reference collections: any signed-in user reads; staff writes.
    match /{coll}/{docId}
      where coll in ['students','companies','jobs','drives','assessments','interviews',
                     'tracking','offers','internships','notifications','announcement',
                     'reports','custom','documents','eligibility','preferences','applications'] {
      allow read: if signedIn();
      allow write: if signedIn() && staff();
    }

    // Employer portal: employers manage their own postings; staff manage all.
    match /employer/{docId} {
      allow read: if signedIn();
      allow write: if signedIn() && (staff() || role() == 'Employer');
    }

    // Messaging templates: staff/admin only.
    match /email/{docId} {
      allow read, write: if signedIn() && role() in ['Placement Officer','Administrator','Career Coordinator'];
    }

    // User management + config: administrators only.
    match /users/{docId}   { allow read, write: if signedIn() && role() == 'Administrator'; }
    match /config/{docId}  { allow read, write: if signedIn() && role() == 'Administrator'; }
  }
}
